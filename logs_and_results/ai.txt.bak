    {
      "id": "filter1_tôi_em",
      "componentType": "task",
      "type": "botReplyFilter",
      "name": "Filter Bot Reply - tôi → em",
      "properties": {
        "regex": "(?:Tôi|tôi)",
        "replace": "em"
      }
    },
    {
      "id": "filter2_chúng_bên",
      "componentType": "task",
      "type": "botReplyFilter",
      "name": "Filter Bot Reply - chúng tôi → bên em",
      "properties": {
        "regex": "(?:chúng tôi|Chúng tôi|chúng em|Chúng em|chúng mình|Chúng mình)",
        "replace": "bên em"
      }
    },
    {
      "id": "filter3_bot_AI",
      "componentType": "task",
      "type": "botReplyFilter",
      "name": "Filter Bot Reply - bot/AI → tư vấn viên",
      "properties": {
        "regex": "(?:trợ lý ảo|chatbot|Chatbot|bot|Bot| AI )",
        "replace": " tư vấn viên "
      }
    },
    {
      "id": "filter4_bạn",
      "componentType": "task",
      "type": "botReplyFilter",
      "name": "Filter Bot Reply - bạn → Anh/Chị",
      "properties": {
        "regex": "(?:bạn|Bạn)",
        "replace": "Anh/Chị"
      }
    },
    {
      "id": "filter5_không_biết",
      "componentType": "task",
      "type": "botReplyFilter",
      "name": "Filter Bot Reply - tôi không biết → em chưa có thông tin",
      "properties": {
        "regex": "(?:tôi không biết|tôi không có thông tin|em không biết)",
        "replace": "em chưa có thông tin chi tiết về phần này"
      }
    }
