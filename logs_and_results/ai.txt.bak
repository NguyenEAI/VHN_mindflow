        "internal_staff": [
          {
            "id": "is2_qna_internal",
            "type": "qna",
            "componentType": "task",
            "name": "AI QnA Internal Handler",
            "properties": {
              "instruction": "# Role\n{{ session.extra.assistant_role }}\nBạn đang hỗ trợ NHÂN VIÊN NỘI BỘ của Y dược VHN.\n\n## Tone\n{{ session.extra.assistant_tone }}\n\n## Xưng hô\n{{ session.extra.vn_pronoun }}\n\n# Quy trình xử lý\nBước 1: Đọc TOÀN BỘ chat history để xem trong cuộc hội thoại trước đó User đã từng cung cấp **Bộ phận** (department) và **Mã số nhân viên** (format chữ+số, VD: MKT001, SALES12) chưa.\n\nBước 2:\n- Nếu chat history ĐÃ có cả Bộ phận + Mã NV (hoặc User vừa cung cấp ở tin nhắn này) → ghi nhận xác thực thành công, mở đầu: \"Dạ, em đã ghi nhận thông tin Anh/Chị. Em xin phép trả lời ạ:\" rồi trả lời câu hỏi nội bộ dựa trên Knowledge B2B (liệt kê SP, thống kê theo vendor, phác đồ điều trị, so sánh phác đồ...).\n- Nếu CHƯA có → trả lời chính xác: \"Dạ, để em hỗ trợ thông tin nội bộ, Anh/Chị vui lòng cho em xin Bộ phận và Mã số nhân viên để xác thực ạ. Ví dụ: 'Phòng Marketing - MKT001'.\"\n\n# Constraint\n- CHỈ trả lời nếu Knowledge có thông tin. KHÔNG bịa.\n- KHÔNG để lộ giá sỉ chi tiết trừ khi Knowledge ghi rõ.\n- Trả lời ngắn gọn, bullet-point, dưới 200 từ.\n- Luôn xưng 'em', gọi NV là 'Anh/Chị'.",
              "dataset_uuid": "753ca5a0-738a-47a1-8cea-b50ea63a925c",
              "dataset_qa_uuid": "0c8f748e-c2a3-4e49-81c8-abef5bc014a9",
              "rag_query": "",
              "limit": "5",
              "api_key": "",
              "knowledge": "{{ knowledge_from_rag }}",
              "knowledge_aware": true,
              "chat_history_aware": true,
              "human_input_aware": true,
              "varReply": "bot_reply",
              "temperature": "0.5",
              "max_tokens": "1500",
              "stop": "",
              "stop_regex": "",
              "pattern": "",
              "json_mode": false,
              "multimodal_mode": false,
              "tools": "",
              "agent_loop": false,
              "llm_alt_model": "gpt-4o-mini"
            }
          },
          {
            "id": "is3_clear_topic",
            "componentType": "task",
